# OpenRAG connection
OPENRAG_API_KEY=orag_your_key_here
OPENRAG_URL=http://localhost:3000

# Hugging Face token (required for pyannote.audio diarization model)
HF_TOKEN=hf_your_token_here

# Pipeline configuration (optional)
AUDIO_DIR=./audio
TRANSCRIPTS_DIR=./transcripts
STATE_FILE=./state.json
LOG_LEVEL=INFO