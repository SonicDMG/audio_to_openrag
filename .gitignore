# =============================================================================
# uv (package manager)
# =============================================================================
# uv.lock is intentionally TRACKED — it pins reproducible installs.
# Do NOT add uv.lock here.

# =============================================================================
# Environment / secrets  ← OWASP: never commit credentials
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets/

# =============================================================================
# Pipeline runtime artifacts
# =============================================================================
# Downloaded audio files (can be large; re-downloadable)
audio/
# Generated transcript Markdown files
transcripts/
# Idempotency state (machine-local; not shareable across users)
state.json
# Temporary atomic-write files created by state.py
*.tmp

# =============================================================================
# ML model caches (large binary files; downloaded on first run)
# =============================================================================
# Hugging Face / pyannote model cache
.cache/
models/
# faster-whisper / CTranslate2 model directories
whisper-*/
ct2-*/

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
pip-log.txt
pip-delete-this-directory.txt

# =============================================================================
# Stray pip / installer output files
# =============================================================================
=*
pip-*.txt

